{
  "expo": {
    "name": "Jaitang",
    "slug": "jaitang-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "jaitang",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chinnakrit.jaitang"
    },
    "android": {
      "package": "com.chinnakrit.jaitang",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
