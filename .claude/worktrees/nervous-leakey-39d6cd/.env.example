# Copy to .env (real values stay out of git via .gitignore).
# Same Supabase project as the web app — DB is shared.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Google OAuth via Supabase Auth. Use the iOS/Android client IDs from
# Google Cloud Console (separate from the web client used by Auth.js).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
